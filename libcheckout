function checkout() {
  local use_cache=${1:-""}
  if [ -z "${SEMAPHORE_GIT_BRANCH}" ] || [ -z "${SEMAPHORE_GIT_URL}" ] || [ -z "${SEMAPHORE_GIT_DIR}" ] || [ -z "${SEMAPHORE_GIT_SHA}" ]; then
    checkout::validation_message
    return 1
  fi

  rm -rf "$SEMAPHORE_GIT_DIR"

  if [ "$use_cache" = "--use-cache" ]; then
    echo "[Experimental stability] Using cached Git repository."
    checkout::use_cache
  else
    if [ -n "${SEMAPHORE_GIT_REF_TYPE:-}" ]; then
      checkout::refbased
    else
      checkout::shallow
    fi

    exit_code=$?
    if [ "$exit_code" -ne "0" ]; then
      checkout::metric 0
    fi

    return $exit_code
  fi
}

function checkout::validation_message() {
  echo "[CHECKOUT ERROR] Some of these variables are unset:"
  echo "SEMAPHORE_GIT_URL=$SEMAPHORE_GIT_URL"
  echo "SEMAPHORE_GIT_DIR=$SEMAPHORE_GIT_DIR"
  echo "SEMAPHORE_GIT_BRANCH=$SEMAPHORE_GIT_BRANCH"
  echo "SEMAPHORE_GIT_SHA=$SEMAPHORE_GIT_SHA"
}

function checkout::use_cache() {
  export CACHE_FAIL_ON_ERROR="true"

  if ! cache restore git-cache-; then
    echo "Failed to restore from the cache"
    rm -rf "${SEMAPHORE_GIT_DIR}"
  fi

  if [ -d "$HOME/$SEMAPHORE_GIT_DIR" ]; then
    checkout::fetch
  else
    checkout::clone
  fi

  # SC2181: checking the last command's exit code
  # with $? simplifies the control flow of this function.
  # shellcheck disable=SC2181
  if [ "$?" -eq "0" ]; then
    checkout::cache_store
  else
    return 1
  fi
}

function checkout::fetch() {
  echo "Restored cache"
  cd "${HOME}/${SEMAPHORE_GIT_DIR}" || exit
  git remote prune origin
  retry git fetch --tags origin

  checkout::switch_revision
}

function checkout::clone() {
  checkout::git_clone "${SEMAPHORE_GIT_URL}" "${SEMAPHORE_GIT_DIR}"
  cd "${SEMAPHORE_GIT_DIR}" || exit

  checkout::switch_revision
}

function checkout::reset_to_sha {
  if checkout::checkrevision; then
    git reset --hard "${SEMAPHORE_GIT_SHA}" 2>/dev/null
    checkout::metric "$(du -s . | awk '{ print $1 }')"
    return 0
  else
    return 1
  fi
}

function checkout::switch_revision() {
  if [ "${SEMAPHORE_GIT_REF_TYPE:-""}" = "pull-request" ]; then
    if ! retry git fetch origin +"${SEMAPHORE_GIT_REF}": 2>/dev/null; then
      echo "Reference: ${SEMAPHORE_GIT_REF} not found .... Exiting"

      return 1
    else
      checkout::reset_to_sha
    fi

  elif [ "${SEMAPHORE_GIT_REF_TYPE:-''}" = "tag" ]; then
    if ! git checkout -qf "${SEMAPHORE_GIT_TAG_NAME}"; then
      echo "Release $SEMAPHORE_GIT_TAG_NAME not found .... Exiting"

      return 1
    else
      checkout::metric "$(du -s . | awk '{ print $1 }')"
      echo "HEAD is now at ${SEMAPHORE_GIT_SHA} Release ${SEMAPHORE_GIT_TAG_NAME}"

      return 0
    fi

  else
    local branch_origin="origin/$SEMAPHORE_GIT_BRANCH"

    if [[ -n $(git show-ref "${SEMAPHORE_GIT_REF}") ]]; then
      git checkout "${SEMAPHORE_GIT_BRANCH}"
    else
      git checkout -b "${SEMAPHORE_GIT_BRANCH}" -t "${branch_origin}";
    fi

    checkout::reset_to_sha
  fi
}

function checkout::cache_store() {
  # update cache if older then 72h -> 25920s
  SEMAPHORE_GIT_CACHE_AGE="${SEMAPHORE_GIT_CACHE_AGE:-259200}"

  local cache_key
  local cache_age
  cache_key="$(cache list 2>&1 | grep git-cache- || true )"
  if [[ -n "$cache_key" ]];then 
    cache_key=$(echo "${cache_key}" | awk '{ print $1 }'| head -1)
  fi
  cache_age=$(echo "${cache_key}" | cut -d'-' -f8)

  if [[ -n "$cache_age" ]] && [[ $cache_age =~ ^[0-9]+$ ]]; then
    local diff=$(($(date +%s) - cache_age))
    echo "diff: $diff"

    if (( diff > SEMAPHORE_GIT_CACHE_AGE )); then
      echo "Git cache outdated, refreshing..."
      cd ..
      checkout::cleanupcache
      cache store "git-cache-$SEMAPHORE_JOB_ID-$(date +%s)" "${SEMAPHORE_GIT_DIR}"
      cd "${SEMAPHORE_GIT_DIR}" || exit
    else
      echo "Git cache up-to-data."
    fi

  else
    echo "No git cache... caching"
    cd ..
    cache store "git-cache-${SEMAPHORE_JOB_ID}-$(date +%s)" "${SEMAPHORE_GIT_DIR}"
    cd "${SEMAPHORE_GIT_DIR}" || exit
  fi
}

function checkout::cleanupcache {
  if [ -z "${SEMAPHORE_GIT_CACHE_KEEP:-""}" ]; then
    SEMAPHORE_GIT_CACHE_KEEP=0
  fi
  local k=$SEMAPHORE_GIT_CACHE_KEEP

  local list=()
  while IFS='' read -r line; do list+=("$line"); done < <(cache list 2>&1 | grep git-cache- | awk '{ print $1 }')

  for i in "${list[@]:$k}"; do
    cache delete "${i}"
  done

}

function checkout::checkrevision {
  if ! git rev-list HEAD.."${SEMAPHORE_GIT_SHA}" 2>/dev/null; then
    echo "Revision: ${SEMAPHORE_GIT_SHA} not found .... Exiting"
    return 1
  fi
}

function checkout::branch_checkout {
  if ! git checkout -f "$SEMAPHORE_GIT_BRANCH"; then
    echo "Branch: ${SEMAPHORE_GIT_BRANCH} not found .... Exiting"
    return 1
  fi
}

function checkout::shallow() {
  if [ -z "${SEMAPHORE_GIT_DEPTH:-""}" ]; then
    SEMAPHORE_GIT_DEPTH=50
  fi
  echo "Performing shallow clone with depth: $SEMAPHORE_GIT_DEPTH"

  checkout::git_clone --depth "${SEMAPHORE_GIT_DEPTH}" -b "${SEMAPHORE_GIT_BRANCH}" "${SEMAPHORE_GIT_URL}" "${SEMAPHORE_GIT_DIR}"
  local clone_rc=$?

  if [ "$clone_rc" -ne 0 ]; then
    # Only a genuinely missing branch justifies downloading full history.
    # Transient/network failures and auth/repo-not-found errors must not
    # silently escalate to an expensive full-history clone (see
    # checkout::should_full_clone_fallback).
    if ! checkout::should_full_clone_fallback "$clone_rc"; then
      echo "[checkout] Shallow clone failed (${CHECKOUT_LAST_CLONE_CLASS:-unknown}); not falling back to full-history clone"
      return 1
    fi

    if [ "${CHECKOUT_LAST_CLONE_CLASS:-}" = "shallow-unsupported" ]; then
      echo "Server does not support shallow clone; performing full clone"
    else
      echo "Branch not found performing full clone"
    fi
    checkout::git_clone "${SEMAPHORE_GIT_URL}" "${SEMAPHORE_GIT_DIR}"
    cd "$SEMAPHORE_GIT_DIR" || exit

    if ! checkout::branch_checkout; then
      return 1
    fi

    if checkout::checkrevision; then
      git reset --hard "${SEMAPHORE_GIT_SHA}" 2>/dev/null
    else
      return 1
    fi
  else
    cd "${SEMAPHORE_GIT_DIR}" || exit

    if ! git reset --hard "${SEMAPHORE_GIT_SHA}" 2>/dev/null; then
      echo "SHA: $SEMAPHORE_GIT_SHA not found performing full clone"
      retry git fetch --unshallow

      if checkout::checkrevision; then
        git reset --hard "${SEMAPHORE_GIT_SHA}" 2>/dev/null
      else
        return 1
      fi
    fi
  fi

  checkout::metric "$(du -s . | awk '{ print $1 }')"
}

function checkout::refbased() {
  if [ -z "${SEMAPHORE_GIT_DEPTH:-""}" ]; then
    SEMAPHORE_GIT_DEPTH=50
  fi

  if [ "${SEMAPHORE_GIT_REF_TYPE:-""}" = "pull-request" ]; then
    checkout::git_clone --depth "${SEMAPHORE_GIT_DEPTH}" "${SEMAPHORE_GIT_URL}" "${SEMAPHORE_GIT_DIR}"
    cd "${SEMAPHORE_GIT_DIR}" || exit

    # Try fetching refs/objects with a depth.
    if retry git fetch --depth "${SEMAPHORE_GIT_DEPTH}" origin +"${SEMAPHORE_GIT_REF}": 2>/dev/null; then
      git checkout -qf FETCH_HEAD
      echo "HEAD is now at ${SEMAPHORE_GIT_SHA}"

      return 0
    fi

    # Fetch with depth failed, fallback to not using a depth.
    if retry git fetch origin +"${SEMAPHORE_GIT_REF}": 2>/dev/null; then
      git checkout -qf FETCH_HEAD
      echo "HEAD is now at ${SEMAPHORE_GIT_SHA}"

      return 0
    fi

    echo "Revision: ${SEMAPHORE_GIT_SHA} not found .... Exiting"
    return 1
  fi

  if [ "${SEMAPHORE_GIT_REF_TYPE:-""}" = "tag" ]; then
    if ! checkout::git_clone --depth "${SEMAPHORE_GIT_DEPTH}" -b "${SEMAPHORE_GIT_TAG_NAME}" "${SEMAPHORE_GIT_URL}" "${SEMAPHORE_GIT_DIR}"; then
      echo "Release $SEMAPHORE_GIT_TAG_NAME not found .... Exiting"
      return 1
    else
      cd "${SEMAPHORE_GIT_DIR}" || exit
      git checkout -qf "${SEMAPHORE_GIT_TAG_NAME}"
      echo "HEAD is now at ${SEMAPHORE_GIT_SHA} Release ${SEMAPHORE_GIT_TAG_NAME}"

      return 0
    fi
  fi

  checkout::shallow
}

function checkout::metric() {
  if [[ "${SEMAPHORE_TOOLBOX_METRICS_ENABLED:-''}" == "true" ]]; then
    ref_type=${SEMAPHORE_GIT_REF_TYPE:-""}
    size=${1:-"0"}
    [[ $size -gt 0 ]] && status='success' || status='fail'
    echo "libcheckout,provider=$SEMAPHORE_GIT_PROVIDER,reftype=$ref_type,status=$status size=$1" >> /tmp/toolbox_metrics
  fi
}

# === Slow clone detection and resilient retry ===
# Enabled via SEMAPHORE_GIT_CLONE_SLOW_RETRY=true
# When disabled (default), checkout::git_clone delegates to `retry git clone`

function checkout::git_clone() {
  if [ "${SEMAPHORE_GIT_CLONE_SLOW_RETRY:-false}" = "true" ]; then
    checkout::resilient_clone "$@"
  else
    retry git clone "$@"
  fi
}

# Emits a structured, greppable token for a resilient-clone lifecycle event so
# the new path is observable in job logs (and in /tmp/toolbox_metrics when
# SEMAPHORE_TOOLBOX_METRICS_ENABLED=true) ahead of any default-on rollout.
# Events: tier1_retry, tier1_success, definitive_error, tier2_enter,
# tier2_success, tier2_exhausted, doh_no_endpoint, stall_kill, wall_clock_kill.
function checkout::resilient_event() {
  local event="$1"
  echo "[checkout] event=${event}"
  if [[ "${SEMAPHORE_TOOLBOX_METRICS_ENABLED:-}" == "true" ]]; then
    # Default the provider tag to "unknown" — some metric backends reject empty
    # tag values, which would silently drop the whole line.
    echo "libcheckout_resilient,provider=${SEMAPHORE_GIT_PROVIDER:-unknown},event=${event} count=1" >> /tmp/toolbox_metrics
  fi
}

# One-time deprecation notice. The throughput knobs were renamed to align with
# git's native http.lowSpeed* gate; legacy values are still honoured (mapped in
# checkout::clone_with_speed_check), this only nudges operators to migrate.
function checkout::warn_legacy_env() {
  if [ -n "${SEMAPHORE_GIT_CLONE_SLOW_THRESHOLD:-}" ] && [ -z "${SEMAPHORE_GIT_CLONE_LOW_SPEED_LIMIT:-}" ]; then
    echo "[checkout] WARNING: SEMAPHORE_GIT_CLONE_SLOW_THRESHOLD is deprecated; honouring it as SEMAPHORE_GIT_CLONE_LOW_SPEED_LIMIT (bytes/sec)."
  fi
  if [ -n "${SEMAPHORE_GIT_CLONE_SLOW_TIMEOUT:-}" ] && [ -z "${SEMAPHORE_GIT_CLONE_LOW_SPEED_TIME:-}" ]; then
    echo "[checkout] WARNING: SEMAPHORE_GIT_CLONE_SLOW_TIMEOUT is deprecated; honouring it as SEMAPHORE_GIT_CLONE_LOW_SPEED_TIME (seconds)."
  fi
}

function checkout::resilient_clone() {
  # Default retry count matches the legacy `retry` helper (3 attempts) so the
  # resilient path is not weaker than the path it replaces.
  local retry_count="${SEMAPHORE_GIT_CLONE_RETRY_COUNT:-3}"
  local alt_ip_retries="${SEMAPHORE_GIT_CLONE_ALT_IP_RETRIES:-3}"
  local target_dir="${SEMAPHORE_GIT_DIR}"

  # Guard against non-numeric overrides flowing into seq / arithmetic below.
  [[ "$retry_count" =~ ^[0-9]+$ ]] && [ "$retry_count" -ge 1 ] || retry_count=3
  [[ "$alt_ip_retries" =~ ^[0-9]+$ ]] || alt_ip_retries=3

  checkout::warn_legacy_env
  CHECKOUT_LAST_CLONE_CLASS="unknown"

  # Tier 1: normal clone under the slow/stall detection in clone_with_speed_check.
  local attempt
  local last_result=0
  local class="unknown"
  for attempt in $(seq 1 "${retry_count}"); do
    checkout::clone_with_speed_check git clone "$@"
    last_result=$?

    if [ "$last_result" -eq 0 ]; then
      CHECKOUT_LAST_CLONE_CLASS="ok"
      checkout::resilient_event tier1_success
      return 0
    fi

    if [ "$last_result" -eq 2 ]; then
      # git exited on its own; inspect why before wasting retries / alt-IP work.
      class="$(checkout::classify_clone_error "${CHECKOUT_CLONE_ERRLOG:-}")"
      case "$class" in
        notfound-branch | notfound-repo | auth | shallow-unsupported)
          # Definitive git-level outcomes: retrying or switching endpoints will
          # not help. Fail fast with rc=3; the caller decides whether a
          # full-history clone is a valid recovery (see should_full_clone_fallback).
          echo "[checkout] Clone failed with a definitive error (${class}); failing fast without retry or endpoint fallback"
          CHECKOUT_LAST_CLONE_CLASS="$class"
          checkout::resilient_event definitive_error
          rm -rf "${target_dir}"
          return 3
          ;;
      esac
    else
      class="stall"
    fi

    if [ "$attempt" -lt "${retry_count}" ]; then
      if [ "$last_result" -eq 1 ]; then
        echo "[checkout] Clone stalled, retrying... (attempt ${attempt}/${retry_count})"
      else
        echo "[checkout] Clone failed (${class}), retrying... (attempt ${attempt}/${retry_count})"
      fi
      checkout::resilient_event tier1_retry
      rm -rf "${target_dir}"
      sleep 2
    fi
  done

  CHECKOUT_LAST_CLONE_CLASS="$class"
  echo "[checkout] Clone failed after ${retry_count} attempts, trying alternative endpoints..."
  checkout::resilient_event tier2_enter

  # Tier 2: parse host + port from SEMAPHORE_GIT_URL, then resolve alt IPs via DoH.
  # Only reached for transient/network failures — definitive git errors already
  # returned above, so we never run DoH + alt-IP work on a 128-type failure.
  local git_host git_port
  if [[ "${SEMAPHORE_GIT_URL}" == https://* ]]; then
    git_host="${SEMAPHORE_GIT_URL#https://}"
    git_host="${git_host%%/*}"   # strip path
    git_host="${git_host#*@}"    # strip optional userinfo (user[:pass]@)
    git_host="${git_host%%:*}"   # strip optional :port so the gate sees a bare host
    git_port=443
  elif [[ "${SEMAPHORE_GIT_URL}" == ssh://* ]]; then
    local rest="${SEMAPHORE_GIT_URL#ssh://}"
    rest="${rest#*@}"
    if [[ "$rest" =~ ^[^/]+:[0-9]+ ]]; then
      git_host="${rest%%:*}"
      local tail="${rest#*:}"
      git_port="${tail%%/*}"
    else
      git_host="${rest%%/*}"
      git_port=22
    fi
  else
    local rest="${SEMAPHORE_GIT_URL#*@}"
    git_host="${rest%%:*}"
    git_port=22
  fi

  # GeoDNS-based alt-IP fallback is GitHub-specific. github.com is the HTTPS and
  # SCP-form host; ssh.github.com is GitHub's SSH-over-443 host — both are
  # eligible. Everything else is declined.
  case "$git_host" in
    github.com | ssh.github.com) ;;
    *)
      echo "[checkout] Alternative endpoint fallback only supported for github.com (got: ${git_host})"
      return 1
      ;;
  esac

  # SSH alt-IP routing needs nc. Check once, up front, instead of emitting the
  # same warning on every alt-IP iteration (and skip the DoH work entirely).
  if [[ "${SEMAPHORE_GIT_URL}" != https://* ]] && ! command -v nc >/dev/null 2>&1; then
    echo "[checkout] 'nc' not available; cannot route SSH clone through alternative endpoint"
    return 1
  fi

  local current_ip
  current_ip=$(dig +short "$git_host" | head -1)

  local alt_ips
  alt_ips=$(checkout::resolve_alt_ips "$git_host" "$current_ip")

  if [ -z "$alt_ips" ]; then
    echo "[checkout] No alternative endpoints found"
    checkout::resilient_event doh_no_endpoint
    return 1
  fi

  local alt_count=0
  local alt_ip
  while IFS= read -r alt_ip; do
    [ -z "$alt_ip" ] && continue
    alt_count=$((alt_count + 1))
    [ "$alt_count" -gt "${alt_ip_retries}" ] && break

    echo "[checkout] Switching to alternative GitHub endpoint (${alt_ip})"
    rm -rf "${target_dir}"

    if checkout::clone_with_alt_ip "$alt_ip" "$git_host" "$git_port" git clone "$@"; then
      checkout::resilient_event tier2_success
      return 0
    fi

    echo "[checkout] Alternative endpoint (${alt_ip}) also failed, trying next..."
  done <<< "$alt_ips"

  echo "[checkout] All clone attempts failed"
  checkout::resilient_event tier2_exhausted
  return 1
}

# Decides whether a failed shallow clone should fall back to a full-history
# clone. A full clone is a valid recovery only for failures it can actually fix.
# Returns 0 (fall back) or 1 (do not fall back).
function checkout::should_full_clone_fallback() {
  local clone_rc="$1"

  if [ "${SEMAPHORE_GIT_CLONE_SLOW_RETRY:-false}" = "true" ]; then
    # Resilient path reports why it failed: rc=3 is a definitive git error and
    # carries CHECKOUT_LAST_CLONE_CLASS; rc=1 is a transient/network/stall
    # failure where escalating to full history just multiplies bandwidth.
    # Escalate only for failures a non-shallow clone genuinely recovers:
    #   * notfound-branch    — the branch exists but not at the shallow depth /
    #                          the -b ref needs full history to resolve,
    #   * shallow-unsupported — server/proxy can't do shallow; full clone omits
    #                          --depth and succeeds.
    # Never for auth / repo-not-found / transient — a full clone can't help.
    if [ "$clone_rc" -eq 3 ]; then
      case "${CHECKOUT_LAST_CLONE_CLASS:-}" in
        notfound-branch | shallow-unsupported) return 0 ;;
      esac
    fi
    return 1
  fi

  # Legacy (non-resilient) path: preserve the historical behavior of always
  # attempting a full clone on any shallow failure.
  return 0
}

# Classifies a captured git clone error log into a coarse failure class so
# callers can decide on retries, alt-IP fallback, and full-clone escalation.
# Echoes one of:
#   shallow-unsupported | notfound-branch | notfound-repo | auth | network | unknown
function checkout::classify_clone_error() {
  local log="${1:-}"
  if [ -z "$log" ] || [ ! -s "$log" ]; then
    echo "unknown"
    return
  fi

  local txt
  txt="$(tr '[:upper:]' '[:lower:]' < "$log")"

  case "$txt" in
    *"does not support shallow"* | *"dumb http transport does not support"*)
      # e.g. "fatal: dumb http transport does not support shallow capabilities"
      # A non-shallow (full) clone is the correct recovery for this.
      echo "shallow-unsupported"
      ;;
    *"remote branch"*"not found in upstream"* | *"could not find remote branch"* | *"not found in upstream"*)
      # The bare "branch 'x' not found in upstream" form (no "remote branch")
      # is still a missing branch — keep it here, not under notfound-repo.
      echo "notfound-branch"
      ;;
    *"repository not found"* | *"does not appear to be a git repository"*)
      echo "notfound-repo"
      ;;
    *"authentication failed"* | *"permission denied"* | *"could not read username"* | *"invalid username or password"* | *"access denied"*)
      echo "auth"
      ;;
    *"could not resolve host"* | *"couldn't resolve host"* | *"connection timed out"* | *"connection refused"* | *"failed to connect"* | *"network is unreachable"* | *"unexpected disconnect"* | *"early eof"* | *"rpc failed"* | *"connection reset"* | *"timed out"* | *"ssl"* | *"tls"*)
      echo "network"
      ;;
    *)
      echo "unknown"
      ;;
  esac
}

function checkout::clone_with_speed_check() {
  # Runs a git clone under slow/stall detection.
  # Returns: 0 = success, 1 = aborted by a watchdog, 2 = git error.
  #
  # DEFAULT-ON slow detection is delegated entirely to git/curl via
  # http.lowSpeedLimit / http.lowSpeedTime (injected below for HTTP(S) clones).
  # curl measures *network* throughput — bytes actually read off the wire — so
  # it never confuses CPU-bound phases (resolving deltas, checkout), server-side
  # "Compressing objects" lulls, or the pack->loose-object rewrite (which
  # shrinks on-disk size) for "slow". That is exactly the false-positive class a
  # du-based throughput/stall proxy produces, so du is NOT used by default. When
  # the wire goes quiet git aborts on its own and we classify the exit as a
  # network failure.
  #
  # The du-based backstops below are OPT-IN for HTTP(S) (default off — the
  # low-speed gate already bounds it without du's false positives). For SSH/SCP
  # there is NO low-speed gate, so a hung SSH clone would otherwise block until
  # the OS network timeout (minutes); there the stall guard defaults ON with a
  # conservative bound (SEMAPHORE_GIT_CLONE_SSH_STALL_TIMEOUT, default 60s).
  #   * stall guard (SEMAPHORE_GIT_CLONE_STALL_TIMEOUT) — no new on-disk bytes
  #     for N seconds after grace,
  #   * wall-clock cap (SEMAPHORE_GIT_CLONE_OVERALL_TIMEOUT) — absolute deadline.
  #
  # http.lowSpeedLimit defaults to 1000 B/s: low enough never to trip a healthy
  # CI link, high enough to catch a wedged transfer within low_time seconds.
  # Legacy SEMAPHORE_GIT_CLONE_SLOW_THRESHOLD / _SLOW_TIMEOUT map onto
  # http.lowSpeedLimit / _TIME (see checkout::warn_legacy_env).
  local low_limit="${SEMAPHORE_GIT_CLONE_LOW_SPEED_LIMIT:-${SEMAPHORE_GIT_CLONE_SLOW_THRESHOLD:-1000}}"
  local low_time="${SEMAPHORE_GIT_CLONE_LOW_SPEED_TIME:-${SEMAPHORE_GIT_CLONE_SLOW_TIMEOUT:-20}}"

  # Per-transport default for the stall guard.
  local stall_default=0
  case "${SEMAPHORE_GIT_URL:-}" in
    https://* | http://*) stall_default=0 ;;
    *)                    stall_default="${SEMAPHORE_GIT_CLONE_SSH_STALL_TIMEOUT:-60}" ;;
  esac
  local stall_timeout="${SEMAPHORE_GIT_CLONE_STALL_TIMEOUT:-$stall_default}"
  local overall_timeout="${SEMAPHORE_GIT_CLONE_OVERALL_TIMEOUT:-0}"
  local grace="${SEMAPHORE_GIT_CLONE_SLOW_GRACE:-15}"
  local check_interval="${SEMAPHORE_GIT_CLONE_CHECK_INTERVAL:-5}"
  local target_dir="${SEMAPHORE_GIT_DIR}"

  # Validate numerics; fall back to defaults rather than feed garbage to git
  # config / arithmetic / sleep.
  [[ "$low_limit"       =~ ^[0-9]+$ ]] || low_limit=1000
  [[ "$low_time"        =~ ^[0-9]+$ ]] || low_time=20
  [[ "$stall_timeout"   =~ ^[0-9]+$ ]] || stall_timeout=0
  [[ "$overall_timeout" =~ ^[0-9]+$ ]] || overall_timeout=0
  [[ "$grace"           =~ ^[0-9]+$ ]] || grace=15
  { [[ "$check_interval" =~ ^[0-9]+$ ]] && [ "$check_interval" -ge 1 ]; } || check_interval=5

  # Inject git/curl-native slow detection for HTTP(S) clones. We only touch a
  # command that starts with `git`; everything else (test stubs, SSH) is run
  # verbatim and relies on the opt-in backstops below.
  local -a cmd=("$@")
  if [ "${cmd[0]:-}" = "git" ] && { [[ "${SEMAPHORE_GIT_URL}" == https://* ]] || [[ "${SEMAPHORE_GIT_URL}" == http://* ]]; }; then
    cmd=("${cmd[0]}" -c "http.lowSpeedLimit=${low_limit}" -c "http.lowSpeedTime=${low_time}" "${cmd[@]:1}")
  fi

  [ -n "${CHECKOUT_CLONE_ERRLOG:-}" ] && rm -f "${CHECKOUT_CLONE_ERRLOG}"
  CHECKOUT_CLONE_ERRLOG="$(mktemp 2>/dev/null || echo "/tmp/checkout_clone_err.$$")"

  # Launch the clone in its own process group (job control) so the entire
  # process tree — git, git-remote-https, ssh, curl helpers — can be signalled
  # and reaped together. libcheckout is sourced, so capture and restore the
  # caller's monitor-mode state instead of leaking `set -m`.
  local had_monitor=0
  case "$-" in *m*) had_monitor=1 ;; esac
  set -m
  "${cmd[@]}" 2>"${CHECKOUT_CLONE_ERRLOG}" &
  local pid=$!
  [ "$had_monitor" -eq 1 ] || set +m

  # No opt-in du backstop armed: nothing to poll. Just wait for git — for
  # HTTP(S) the injected http.lowSpeedLimit gate is the active slow-detector.
  if [ "$stall_timeout" -eq 0 ] && [ "$overall_timeout" -eq 0 ]; then
    wait "$pid"
    local rc=$?
    cat "${CHECKOUT_CLONE_ERRLOG}" >&2 2>/dev/null
    if [ "$rc" -eq 0 ]; then
      rm -f "${CHECKOUT_CLONE_ERRLOG}"
      return 0
    fi
    return 2
  fi

  local max_size=0
  local stall_seconds=0
  local elapsed=0

  while kill -0 "$pid" 2>/dev/null; do
    sleep "$check_interval"
    kill -0 "$pid" 2>/dev/null || break
    elapsed=$((elapsed + check_interval))

    # Absolute wall-clock cap (opt-in).
    if [ "$overall_timeout" -gt 0 ] && [ "$elapsed" -ge "$overall_timeout" ]; then
      echo "[checkout] Clone exceeded wall-clock cap (${elapsed}s >= ${overall_timeout}s), aborting"
      checkout::resilient_event wall_clock_kill
      checkout::kill_clone "$pid"
      cat "${CHECKOUT_CLONE_ERRLOG}" >&2 2>/dev/null
      return 1
    fi

    # Stall guard (opt-in).
    [ "$stall_timeout" -gt 0 ] || continue

    local cur_size
    cur_size=$(du -sk "${target_dir}" 2>/dev/null | awk '{print $1}')
    cur_size=${cur_size:-0}

    # Startup grace: connection setup and server-side object enumeration can
    # run for seconds with no on-disk growth. Track size but don't arm the
    # stall guard until grace elapses.
    if [ "$elapsed" -lt "$grace" ]; then
      [ "$cur_size" -gt "$max_size" ] && max_size=$cur_size
      continue
    fi

    # Forward progress == a new on-disk high-water mark; otherwise the stall
    # timer advances. Also covers the pre-write case (size never leaves 0) and
    # never fires on a clone that keeps growing.
    if [ "$cur_size" -gt "$max_size" ]; then
      max_size=$cur_size
      stall_seconds=0
    else
      stall_seconds=$((stall_seconds + check_interval))
    fi

    if [ "$stall_seconds" -ge "$stall_timeout" ]; then
      echo "[checkout] Clone stalled: no progress for ${stall_seconds}s, aborting"
      checkout::resilient_event stall_kill
      checkout::kill_clone "$pid"
      cat "${CHECKOUT_CLONE_ERRLOG}" >&2 2>/dev/null
      return 1
    fi
  done

  wait "$pid"
  local exit_code=$?
  cat "${CHECKOUT_CLONE_ERRLOG}" >&2 2>/dev/null

  if [ "$exit_code" -eq 0 ]; then
    rm -f "${CHECKOUT_CLONE_ERRLOG}"
    return 0
  fi
  return 2
}

# Terminates a clone and its whole process group, escalating TERM -> KILL, then
# reaps it so callers never rm -rf a directory a live git is still writing to.
function checkout::kill_clone() {
  local pid="$1"

  # Group-signal only when the child is in its own process group (job control
  # gave it pgid == pid). Falling back to the bare pid avoids the catastrophe
  # of signalling our own group if, for any reason, it was not isolated.
  local pgid self_pgid
  pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')"
  self_pgid="$(ps -o pgid= -p $$ 2>/dev/null | tr -d ' ')"

  local can_group_kill=0
  if [ -n "$pgid" ] && [ "$pgid" != "$self_pgid" ]; then
    can_group_kill=1
  fi

  if [ "$can_group_kill" -eq 1 ]; then
    kill -TERM -- -"$pgid" 2>/dev/null
  else
    kill -TERM "$pid" 2>/dev/null
  fi

  local waited=0
  while kill -0 "$pid" 2>/dev/null && [ "$waited" -lt 5 ]; do
    sleep 1
    waited=$((waited + 1))
  done

  if kill -0 "$pid" 2>/dev/null; then
    if [ "$can_group_kill" -eq 1 ]; then
      kill -KILL -- -"$pgid" 2>/dev/null
    else
      kill -KILL "$pid" 2>/dev/null
    fi
  fi

  wait "$pid" 2>/dev/null
}

# Validates that a string is a syntactically valid dotted-quad IPv4 address.
function checkout::is_valid_ipv4() {
  local ip="${1:-}"
  [[ "$ip" =~ ^([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})$ ]] || return 1
  local octet
  for octet in "${BASH_REMATCH[@]:1:4}"; do
    [ "$octet" -le 255 ] || return 1
  done
  return 0
}

# Queries one DoH provider for one EDNS-client-subnet region and echoes the
# first syntactically valid IPv4 answer that differs from current_ip.
# A DoH response can legitimately carry CNAME 'data' fields (hostnames) or, if
# tampered with, arbitrary strings; never feed an unvalidated value into a git
# config option or an `nc` ProxyCommand — hence the is_valid_ipv4 gate.
function checkout::doh_resolve_one() {
  local provider="$1" git_host="$2" region="$3" current_ip="$4"
  local connect_timeout="$5" max_time="$6"

  local url
  local -a header=()
  case "$provider" in
    google)
      url="https://dns.google/resolve?name=${git_host}&type=A&edns_client_subnet=${region}"
      ;;
    cloudflare)
      url="https://cloudflare-dns.com/dns-query?name=${git_host}&type=A&edns_client_subnet=${region}"
      header=(-H "Accept: application/dns-json")
      ;;
    *)
      return 1
      ;;
  esac

  local response candidate
  # --connect-timeout / --max-time keep tier 2 from hanging when the resolver is
  # blocked or unreachable (common on locked-down self-hosted runners).
  response=$(curl -sf --connect-timeout "${connect_timeout}" --max-time "${max_time}" \
    "${header[@]}" "$url" 2>/dev/null) || return 1

  while IFS= read -r candidate; do
    [ -z "$candidate" ] && continue
    if checkout::is_valid_ipv4 "$candidate" && [ "$candidate" != "$current_ip" ]; then
      echo "$candidate"
      return 0
    fi
  done < <(printf '%s' "$response" | grep -o '"data":"[^"]*"' | sed 's/"data":"//;s/"//')
  return 1
}

function checkout::resolve_alt_ips() {
  local git_host="$1"
  local current_ip="$2"

  # EDNS-client-subnet hints. These /8 netblocks steer GeoDNS toward GitHub's
  # git-capable frontends in geographically distinct regions (US/EU/APAC-ish),
  # yielding edge IPs different from the runner's current one — the whole point
  # of tier 2 when the local-resolved edge is the unhealthy one. Override via
  # SEMAPHORE_GIT_CLONE_ALT_REGIONS if GitHub's GeoDNS mapping shifts.
  local regions
  IFS=',' read -ra regions <<< "${SEMAPHORE_GIT_CLONE_ALT_REGIONS:-74.0.0.0/8,177.0.0.0/8,110.0.0.0/8}"

  # DoH providers, tried in order per region, so dns.google is not a single
  # point of failure for tier 2. (Cloudflare may ignore EDNS-client-subnet, but
  # still provides an alternative resolution when Google DoH is blocked.)
  local providers
  IFS=',' read -ra providers <<< "${SEMAPHORE_GIT_CLONE_DOH_PROVIDERS:-google,cloudflare}"

  local connect_timeout="${SEMAPHORE_GIT_CLONE_DOH_CONNECT_TIMEOUT:-5}"
  local max_time="${SEMAPHORE_GIT_CLONE_DOH_MAX_TIME:-10}"

  local region provider ip
  for region in "${regions[@]}"; do
    ip=""
    for provider in "${providers[@]}"; do
      ip="$(checkout::doh_resolve_one "$provider" "$git_host" "$region" "$current_ip" "$connect_timeout" "$max_time")"
      [ -n "$ip" ] && break
    done
    [ -n "$ip" ] && echo "$ip"
  done | sort -u
}

function checkout::clone_with_alt_ip() {
  local alt_ip="$1"
  local git_host="$2"
  local git_port="$3"
  shift 3
  # $@ is now: git clone [args...]

  # Defense in depth: even though resolve_alt_ips validates, never interpolate
  # an unvalidated IP into git config or a shell command here either.
  if ! checkout::is_valid_ipv4 "$alt_ip"; then
    echo "[checkout] Refusing to use invalid alternative IP: ${alt_ip}"
    return 1
  fi

  if [[ "${SEMAPHORE_GIT_URL}" == https://* ]]; then
    # HTTPS: inject curloptResolve between 'git' and 'clone'
    checkout::clone_with_speed_check git -c "http.curloptResolve=${git_host}:${git_port}:${alt_ip}" "${@:2}"
  else
    # SSH: route through alternative IP via ProxyCommand (needs nc)
    if ! command -v nc >/dev/null 2>&1; then
      echo "[checkout] 'nc' not available; cannot route SSH clone through alternative endpoint"
      return 1
    fi
    # Capture whether GIT_SSH_COMMAND was *set* (even if empty) so we restore
    # the exact prior state instead of conflating "unset" with "set-empty".
    local had_ssh_command=0 orig_ssh_command=""
    if [ -n "${GIT_SSH_COMMAND+x}" ]; then
      had_ssh_command=1
      orig_ssh_command="${GIT_SSH_COMMAND}"
    fi
    export GIT_SSH_COMMAND="${orig_ssh_command:-ssh} -o ProxyCommand='nc ${alt_ip} ${git_port}'"
    checkout::clone_with_speed_check "$@"
    local result=$?
    if [ "$had_ssh_command" -eq 1 ]; then
      export GIT_SSH_COMMAND="$orig_ssh_command"
    else
      unset GIT_SSH_COMMAND
    fi
    return $result
  fi
}

